{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Terux",
  "version": "0.1.0",
  "identifier": "com.terux.terminal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Terux",
        "width": 800,
        "height": 600,
        "minHeight": 116,
        "minWidth": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "devtools": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}